generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Stage 1: the thinnest working slice — projects, documents, tickets.
// File storage, integrations, and compliance tables come in later stages.
model Project {
  id          String     @id @default(cuid())
  name        String
  idea        String
  // Optional Discovery context — filled in via the "Add more context" section
  // on the New Project form. Used to sharpen BRD generation when present.
  audience    String?
  techStack   String?
  constraints String?
  status      String     @default("active")
  isDemo      Boolean    @default(false)
  userId      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]
  tickets     Ticket[]
  sprints     Sprint[]

  @@index([userId])
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String // BRD | PRD | FSD
  content   String
  version   Int      @default(1)
  status    String   @default("draft") // draft | review | approved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, type, version])
}

model Ticket {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  description        String   @default("")
  acceptanceCriteria String   @default("")
  priority           String   @default("medium") // low | medium | high
  estimate           Int?
  status             String   @default("backlog") // backlog | todo | in-progress | done
  completedAt        DateTime?
  sourceSection      String?
  sprintId           String?
  sprint             Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  blockedBy TicketDependency[] @relation("blocked")
  blocks    TicketDependency[] @relation("blocker")
}

model TicketDependency {
  id        String @id @default(cuid())
  ticketId  String
  blockerId String
  ticket    Ticket @relation("blocked", fields: [ticketId], references: [id], onDelete: Cascade)
  blocker   Ticket @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([ticketId, blockerId])
}

// -----------------------------------------------------------------------------
// Auth.js (NextAuth v5) tables — Prisma adapter spec. Purely additive; nothing
// else in the schema depends on these yet.
// -----------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Sprint {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  goal      String   @default("")
  capacity  Int      @default(20)
  startDate DateTime
  endDate   DateTime
  tickets   Ticket[]
  createdAt DateTime @default(now())
}
